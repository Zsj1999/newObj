{"ast":null,"code":"import _toConsumableArray from \"/Users/mac/ZSJ/myproject/zhaopinxitong/node_modules/@babel/runtime/helpers/esm/toConsumableArray.js\";\nimport \"core-js/modules/es.array.concat.js\";\nimport \"core-js/modules/es.array.every.js\";\nimport \"core-js/modules/es.array.filter.js\";\nimport \"core-js/modules/es.array.includes.js\";\nimport \"core-js/modules/es.array.join.js\";\nimport \"core-js/modules/es.array.map.js\";\nimport \"core-js/modules/es.array.slice.js\";\nimport \"core-js/modules/es.array.sort.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.every.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nimport \"core-js/modules/es.number.constructor.js\";\nimport \"core-js/modules/es.object.to-string.js\";\nimport \"core-js/modules/es.set.js\";\nimport \"core-js/modules/es.set.difference.v2.js\";\nimport \"core-js/modules/es.set.intersection.v2.js\";\nimport \"core-js/modules/es.set.is-disjoint-from.v2.js\";\nimport \"core-js/modules/es.set.is-subset-of.v2.js\";\nimport \"core-js/modules/es.set.is-superset-of.v2.js\";\nimport \"core-js/modules/es.set.symmetric-difference.v2.js\";\nimport \"core-js/modules/es.set.union.v2.js\";\nimport \"core-js/modules/es.string.includes.js\";\nimport \"core-js/modules/es.string.iterator.js\";\nimport \"core-js/modules/es.string.trim.js\";\nimport \"core-js/modules/web.dom-collections.iterator.js\";\nimport { jobs, portalMetrics } from \"../mock/jobs\";\nvar emptyJob = {\n  id: \"\",\n  title: \"\",\n  company: \"\",\n  location: \"\",\n  salary: \"\",\n  tags: [],\n  benefits: [],\n  employmentType: \"\",\n  education: \"\",\n  experience: \"\",\n  applicants: 0,\n  description: [],\n  requirements: []\n};\nexport default {\n  name: \"RecruitmentPortal\",\n  data: function data() {\n    return {\n      allJobs: jobs,\n      portalMetrics: portalMetrics,\n      keyword: this.$route.query.keyword || \"\",\n      city: \"全部\",\n      employmentType: \"全部\",\n      experience: \"全部\",\n      sortType: \"latest\",\n      page: 1,\n      pageSize: 12,\n      selectedFeatures: [],\n      drawerVisible: false,\n      selectedJob: emptyJob,\n      drawerWidth: typeof window !== \"undefined\" && window.innerWidth < 768 ? \"100%\" : 560\n    };\n  },\n  computed: {\n    cities: function cities() {\n      return _toConsumableArray(new Set(this.allJobs.map(function (job) {\n        return job.city;\n      })));\n    },\n    employmentTypes: function employmentTypes() {\n      return _toConsumableArray(new Set(this.allJobs.map(function (job) {\n        return job.employmentType;\n      })));\n    },\n    experiences: function experiences() {\n      return _toConsumableArray(new Set(this.allJobs.map(function (job) {\n        return job.experience;\n      })));\n    },\n    featureTags: function featureTags() {\n      return [\"急招\", \"支持远程\", \"Vue2\", \"Spring Boot\", \"校招\", \"六险一金\"];\n    },\n    filteredJobs: function filteredJobs() {\n      var _this = this;\n      var keyword = this.keyword.trim().toLowerCase();\n      var filtered = this.allJobs.filter(function (job) {\n        var matchesKeyword = !keyword || [job.title, job.company, job.city].concat(_toConsumableArray(job.tags)).join(\" \").toLowerCase().includes(keyword);\n        var matchesCity = _this.city === \"全部\" || job.city === _this.city;\n        var matchesEmployment = _this.employmentType === \"全部\" || job.employmentType === _this.employmentType;\n        var matchesExperience = _this.experience === \"全部\" || job.experience === _this.experience;\n        var matchesFeatures = _this.selectedFeatures.every(function (feature) {\n          if (feature === \"急招\") {\n            return job.urgent;\n          }\n          if (feature === \"支持远程\") {\n            return job.remote;\n          }\n          if (feature === \"校招\") {\n            return job.employmentType === \"校招\";\n          }\n          if (feature === \"六险一金\") {\n            return job.benefits.includes(\"六险一金\");\n          }\n          return job.tags.includes(feature);\n        });\n        return matchesKeyword && matchesCity && matchesEmployment && matchesExperience && matchesFeatures;\n      });\n      if (this.sortType === \"salary\") {\n        return filtered.slice().sort(function (a, b) {\n          return b.salaryMax - a.salaryMax;\n        });\n      }\n      if (this.sortType === \"hot\") {\n        return filtered.slice().sort(function (a, b) {\n          return b.applicants - a.applicants;\n        });\n      }\n      return filtered.slice().sort(function (a, b) {\n        return Number(a.id.split(\"-\")[1]) - Number(b.id.split(\"-\")[1]);\n      });\n    },\n    paginatedJobs: function paginatedJobs() {\n      var start = (this.page - 1) * this.pageSize;\n      return this.filteredJobs.slice(start, start + this.pageSize);\n    }\n  },\n  watch: {\n    \"$route.query.keyword\": {\n      immediate: true,\n      handler: function handler(value) {\n        this.keyword = value || \"\";\n        this.page = 1;\n      }\n    }\n  },\n  mounted: function mounted() {\n    window.addEventListener(\"resize\", this.updateDrawerWidth);\n  },\n  beforeDestroy: function beforeDestroy() {\n    window.removeEventListener(\"resize\", this.updateDrawerWidth);\n  },\n  methods: {\n    resetPagination: function resetPagination() {\n      this.page = 1;\n    },\n    toggleFeature: function toggleFeature(tag) {\n      if (this.selectedFeatures.includes(tag)) {\n        this.selectedFeatures = this.selectedFeatures.filter(function (item) {\n          return item !== tag;\n        });\n      } else {\n        this.selectedFeatures = this.selectedFeatures.concat(tag);\n      }\n      this.resetPagination();\n    },\n    changePage: function changePage(page) {\n      this.page = page;\n    },\n    openJob: function openJob(job) {\n      this.selectedJob = job;\n      this.drawerVisible = true;\n    },\n    showFirstJob: function showFirstJob() {\n      this.openJob(this.allJobs[0]);\n    },\n    scrollToList: function scrollToList() {\n      this.$refs.listSection.scrollIntoView({\n        behavior: \"smooth\",\n        block: \"start\"\n      });\n    },\n    updateDrawerWidth: function updateDrawerWidth() {\n      this.drawerWidth = window.innerWidth < 768 ? \"100%\" : 560;\n    }\n  }\n};","map":{"version":3,"names":["jobs","portalMetrics","emptyJob","id","title","company","location","salary","tags","benefits","employmentType","education","experience","applicants","description","requirements","name","data","allJobs","keyword","$route","query","city","sortType","page","pageSize","selectedFeatures","drawerVisible","selectedJob","drawerWidth","window","innerWidth","computed","cities","_toConsumableArray","Set","map","job","employmentTypes","experiences","featureTags","filteredJobs","_this","trim","toLowerCase","filtered","filter","matchesKeyword","concat","join","includes","matchesCity","matchesEmployment","matchesExperience","matchesFeatures","every","feature","urgent","remote","slice","sort","a","b","salaryMax","Number","split","paginatedJobs","start","watch","immediate","handler","value","mounted","addEventListener","updateDrawerWidth","beforeDestroy","removeEventListener","methods","resetPagination","toggleFeature","tag","item","changePage","openJob","showFirstJob","scrollToList","$refs","listSection","scrollIntoView","behavior","block"],"sources":["src/views/RecruitmentPortal.vue"],"sourcesContent":["<template>\n  <div class=\"page\">\n    <section class=\"hero-banner\">\n      <div class=\"hero-copy\">\n        <a-tag color=\"blue\" class=\"hero-tag\">智能招聘中台</a-tag>\n        <h1>一套兼容 PC 与 H5 的招聘系统模板</h1>\n        <p>\n          覆盖职位检索、企业展示、投递管理与数据看板，内置 420 条模拟岗位数据，可直接作为业务原型或项目脚手架继续扩展。\n        </p>\n        <div class=\"hero-actions\">\n          <a-button type=\"primary\" size=\"large\" shape=\"round\" @click=\"scrollToList\">\n            查看岗位\n          </a-button>\n          <a-button size=\"large\" shape=\"round\" @click=\"showFirstJob\">\n            预览职位详情\n          </a-button>\n        </div>\n      </div>\n      <div class=\"hero-panel\">\n        <div v-for=\"metric in portalMetrics\" :key=\"metric.label\" class=\"metric-card\">\n          <div class=\"metric-value\">{{ metric.value }}{{ metric.suffix }}</div>\n          <div class=\"metric-label\">{{ metric.label }}</div>\n        </div>\n      </div>\n    </section>\n\n    <section ref=\"listSection\" class=\"content-grid\">\n      <div class=\"filter-panel\">\n        <a-card :bordered=\"false\" class=\"filter-card\">\n          <div class=\"section-title\">筛选条件</div>\n          <a-input-search\n            v-model=\"keyword\"\n            allow-clear\n            placeholder=\"职位名称 / 企业 / 技能标签\"\n            @search=\"resetPagination\"\n          />\n          <div class=\"filter-group\">\n            <div class=\"filter-label\">城市</div>\n            <a-radio-group v-model=\"city\" button-style=\"solid\" class=\"full-width\" @change=\"resetPagination\">\n              <a-radio-button value=\"全部\">全部</a-radio-button>\n              <a-radio-button v-for=\"item in cities\" :key=\"item\" :value=\"item\">\n                {{ item }}\n              </a-radio-button>\n            </a-radio-group>\n          </div>\n          <div class=\"filter-group\">\n            <div class=\"filter-label\">岗位类型</div>\n            <a-select v-model=\"employmentType\" class=\"full-width\" @change=\"resetPagination\">\n              <a-select-option value=\"全部\">全部</a-select-option>\n              <a-select-option v-for=\"item in employmentTypes\" :key=\"item\" :value=\"item\">\n                {{ item }}\n              </a-select-option>\n            </a-select>\n          </div>\n          <div class=\"filter-group\">\n            <div class=\"filter-label\">经验要求</div>\n            <a-select v-model=\"experience\" class=\"full-width\" @change=\"resetPagination\">\n              <a-select-option value=\"全部\">全部</a-select-option>\n              <a-select-option v-for=\"item in experiences\" :key=\"item\" :value=\"item\">\n                {{ item }}\n              </a-select-option>\n            </a-select>\n          </div>\n          <div class=\"filter-group\">\n            <div class=\"filter-label\">特色标签</div>\n            <div class=\"quick-tags\">\n              <a-checkable-tag\n                v-for=\"tag in featureTags\"\n                :key=\"tag\"\n                :checked=\"selectedFeatures.includes(tag)\"\n                @change=\"toggleFeature(tag)\"\n              >\n                {{ tag }}\n              </a-checkable-tag>\n            </div>\n          </div>\n          <div class=\"filter-group\">\n            <div class=\"filter-label\">排序方式</div>\n            <a-select v-model=\"sortType\" class=\"full-width\">\n              <a-select-option value=\"latest\">最新发布</a-select-option>\n              <a-select-option value=\"salary\">薪资优先</a-select-option>\n              <a-select-option value=\"hot\">投递热度</a-select-option>\n            </a-select>\n          </div>\n          <div class=\"filter-summary\">\n            共筛选出 <span>{{ filteredJobs.length }}</span> 个职位\n          </div>\n        </a-card>\n      </div>\n\n      <div class=\"list-panel\">\n        <a-row :gutter=\"[16, 16]\">\n          <a-col v-for=\"job in paginatedJobs\" :key=\"job.id\" :xs=\"24\" :lg=\"12\">\n            <a-card :bordered=\"false\" class=\"job-card\" @click=\"openJob(job)\">\n              <div class=\"job-card-top\">\n                <div>\n                  <div class=\"job-title-row\">\n                    <h3>{{ job.title }}</h3>\n                    <a-tag v-if=\"job.urgent\" color=\"red\">急招</a-tag>\n                    <a-tag v-if=\"job.remote\" color=\"green\">支持远程</a-tag>\n                  </div>\n                  <div class=\"job-meta\">\n                    {{ job.company }} · {{ job.location }} · {{ job.education }} · {{ job.experience }}\n                  </div>\n                </div>\n                <div class=\"job-salary\">{{ job.salary }}</div>\n              </div>\n              <div class=\"job-tags\">\n                <a-tag v-for=\"tag in job.tags\" :key=\"tag\">{{ tag }}</a-tag>\n              </div>\n              <div class=\"job-benefits\">\n                <span v-for=\"benefit in job.benefits\" :key=\"benefit\">{{ benefit }}</span>\n              </div>\n              <div class=\"job-footer\">\n                <span>{{ job.publishedAt }}</span>\n                <span>{{ job.applicants }} 人投递</span>\n              </div>\n            </a-card>\n          </a-col>\n        </a-row>\n\n        <a-empty v-if=\"!paginatedJobs.length\" description=\"暂无符合条件的职位\" />\n\n        <div class=\"pagination-bar\">\n          <a-pagination\n            :current=\"page\"\n            :page-size=\"pageSize\"\n            :total=\"filteredJobs.length\"\n            :show-size-changer=\"false\"\n            @change=\"changePage\"\n          />\n        </div>\n      </div>\n    </section>\n\n    <a-drawer\n      :visible=\"drawerVisible\"\n      placement=\"right\"\n      :width=\"drawerWidth\"\n      @close=\"drawerVisible = false\"\n    >\n      <template slot=\"title\">\n        <div class=\"drawer-title\">\n          <div>{{ selectedJob.title }}</div>\n          <div class=\"drawer-subtitle\">{{ selectedJob.company }} · {{ selectedJob.location }}</div>\n        </div>\n      </template>\n\n      <div v-if=\"selectedJob.id\" class=\"detail-section\">\n        <div class=\"detail-salary\">{{ selectedJob.salary }}</div>\n        <div class=\"detail-tags\">\n          <a-tag v-for=\"tag in selectedJob.tags\" :key=\"tag\" color=\"blue\">{{ tag }}</a-tag>\n        </div>\n        <a-descriptions :column=\"1\" size=\"small\" bordered>\n          <a-descriptions-item label=\"岗位类型\">{{ selectedJob.employmentType }}</a-descriptions-item>\n          <a-descriptions-item label=\"学历要求\">{{ selectedJob.education }}</a-descriptions-item>\n          <a-descriptions-item label=\"经验要求\">{{ selectedJob.experience }}</a-descriptions-item>\n          <a-descriptions-item label=\"投递人数\">{{ selectedJob.applicants }} 人</a-descriptions-item>\n        </a-descriptions>\n        <div class=\"detail-block\">\n          <div class=\"detail-heading\">岗位职责</div>\n          <ul>\n            <li v-for=\"item in selectedJob.description\" :key=\"item\">{{ item }}</li>\n          </ul>\n        </div>\n        <div class=\"detail-block\">\n          <div class=\"detail-heading\">任职要求</div>\n          <ul>\n            <li v-for=\"item in selectedJob.requirements\" :key=\"item\">{{ item }}</li>\n          </ul>\n        </div>\n        <div class=\"detail-block\">\n          <div class=\"detail-heading\">福利待遇</div>\n          <div class=\"detail-benefits\">\n            <a-tag v-for=\"item in selectedJob.benefits\" :key=\"item\" color=\"green\">{{ item }}</a-tag>\n          </div>\n        </div>\n        <a-button type=\"primary\" size=\"large\" block>立即投递</a-button>\n      </div>\n    </a-drawer>\n  </div>\n</template>\n\n<script>\nimport { jobs, portalMetrics } from \"../mock/jobs\";\n\nconst emptyJob = {\n  id: \"\",\n  title: \"\",\n  company: \"\",\n  location: \"\",\n  salary: \"\",\n  tags: [],\n  benefits: [],\n  employmentType: \"\",\n  education: \"\",\n  experience: \"\",\n  applicants: 0,\n  description: [],\n  requirements: []\n};\n\nexport default {\n  name: \"RecruitmentPortal\",\n  data() {\n    return {\n      allJobs: jobs,\n      portalMetrics,\n      keyword: this.$route.query.keyword || \"\",\n      city: \"全部\",\n      employmentType: \"全部\",\n      experience: \"全部\",\n      sortType: \"latest\",\n      page: 1,\n      pageSize: 12,\n      selectedFeatures: [],\n      drawerVisible: false,\n      selectedJob: emptyJob,\n      drawerWidth: typeof window !== \"undefined\" && window.innerWidth < 768 ? \"100%\" : 560\n    };\n  },\n  computed: {\n    cities() {\n      return [...new Set(this.allJobs.map((job) => job.city))];\n    },\n    employmentTypes() {\n      return [...new Set(this.allJobs.map((job) => job.employmentType))];\n    },\n    experiences() {\n      return [...new Set(this.allJobs.map((job) => job.experience))];\n    },\n    featureTags() {\n      return [\"急招\", \"支持远程\", \"Vue2\", \"Spring Boot\", \"校招\", \"六险一金\"];\n    },\n    filteredJobs() {\n      const keyword = this.keyword.trim().toLowerCase();\n      const filtered = this.allJobs.filter((job) => {\n        const matchesKeyword =\n          !keyword ||\n          [job.title, job.company, job.city, ...job.tags]\n            .join(\" \")\n            .toLowerCase()\n            .includes(keyword);\n        const matchesCity = this.city === \"全部\" || job.city === this.city;\n        const matchesEmployment =\n          this.employmentType === \"全部\" || job.employmentType === this.employmentType;\n        const matchesExperience = this.experience === \"全部\" || job.experience === this.experience;\n        const matchesFeatures = this.selectedFeatures.every((feature) => {\n          if (feature === \"急招\") {\n            return job.urgent;\n          }\n          if (feature === \"支持远程\") {\n            return job.remote;\n          }\n          if (feature === \"校招\") {\n            return job.employmentType === \"校招\";\n          }\n          if (feature === \"六险一金\") {\n            return job.benefits.includes(\"六险一金\");\n          }\n          return job.tags.includes(feature);\n        });\n\n        return matchesKeyword && matchesCity && matchesEmployment && matchesExperience && matchesFeatures;\n      });\n\n      if (this.sortType === \"salary\") {\n        return filtered.slice().sort((a, b) => b.salaryMax - a.salaryMax);\n      }\n\n      if (this.sortType === \"hot\") {\n        return filtered.slice().sort((a, b) => b.applicants - a.applicants);\n      }\n\n      return filtered.slice().sort((a, b) => Number(a.id.split(\"-\")[1]) - Number(b.id.split(\"-\")[1]));\n    },\n    paginatedJobs() {\n      const start = (this.page - 1) * this.pageSize;\n      return this.filteredJobs.slice(start, start + this.pageSize);\n    }\n  },\n  watch: {\n    \"$route.query.keyword\": {\n      immediate: true,\n      handler(value) {\n        this.keyword = value || \"\";\n        this.page = 1;\n      }\n    }\n  },\n  mounted() {\n    window.addEventListener(\"resize\", this.updateDrawerWidth);\n  },\n  beforeDestroy() {\n    window.removeEventListener(\"resize\", this.updateDrawerWidth);\n  },\n  methods: {\n    resetPagination() {\n      this.page = 1;\n    },\n    toggleFeature(tag) {\n      if (this.selectedFeatures.includes(tag)) {\n        this.selectedFeatures = this.selectedFeatures.filter((item) => item !== tag);\n      } else {\n        this.selectedFeatures = this.selectedFeatures.concat(tag);\n      }\n      this.resetPagination();\n    },\n    changePage(page) {\n      this.page = page;\n    },\n    openJob(job) {\n      this.selectedJob = job;\n      this.drawerVisible = true;\n    },\n    showFirstJob() {\n      this.openJob(this.allJobs[0]);\n    },\n    scrollToList() {\n      this.$refs.listSection.scrollIntoView({ behavior: \"smooth\", block: \"start\" });\n    },\n    updateDrawerWidth() {\n      this.drawerWidth = window.innerWidth < 768 ? \"100%\" : 560;\n    }\n  }\n};\n</script>\n\n<style scoped>\n.page {\n  display: flex;\n  flex-direction: column;\n  gap: 24px;\n}\n\n.hero-banner {\n  display: grid;\n  grid-template-columns: minmax(0, 1.4fr) minmax(320px, 1fr);\n  gap: 20px;\n  padding: clamp(24px, 3vw, 40px);\n  border-radius: 28px;\n  background: linear-gradient(135deg, #08142c 0%, #102d65 55%, #1677ff 100%);\n  color: #fff;\n  box-shadow: 0 20px 60px rgba(16, 45, 101, 0.28);\n}\n\n.hero-copy h1 {\n  margin: 18px 0 12px;\n  color: #fff;\n  font-size: clamp(32px, 4vw, 46px);\n  line-height: 1.15;\n}\n\n.hero-copy p {\n  max-width: 640px;\n  color: rgba(255, 255, 255, 0.82);\n  font-size: 16px;\n  line-height: 1.8;\n}\n\n.hero-actions {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 14px;\n  margin-top: 28px;\n}\n\n.hero-panel {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 16px;\n}\n\n.metric-card {\n  padding: 24px 20px;\n  border-radius: 24px;\n  background: rgba(255, 255, 255, 0.12);\n  backdrop-filter: blur(12px);\n}\n\n.metric-value {\n  font-size: clamp(26px, 4vw, 38px);\n  font-weight: 700;\n}\n\n.metric-label {\n  margin-top: 8px;\n  color: rgba(255, 255, 255, 0.76);\n}\n\n.content-grid {\n  display: grid;\n  grid-template-columns: 320px minmax(0, 1fr);\n  gap: 20px;\n}\n\n.filter-card,\n.job-card {\n  border-radius: 24px;\n  box-shadow: 0 12px 40px rgba(17, 31, 65, 0.08);\n}\n\n.section-title {\n  margin-bottom: 18px;\n  font-size: 20px;\n  font-weight: 700;\n  color: #0f172a;\n}\n\n.filter-group {\n  margin-top: 18px;\n}\n\n.filter-label {\n  margin-bottom: 10px;\n  color: #475569;\n  font-weight: 600;\n}\n\n.full-width {\n  width: 100%;\n}\n\n.quick-tags {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 8px;\n}\n\n.filter-summary {\n  margin-top: 18px;\n  padding: 14px 16px;\n  border-radius: 16px;\n  background: #f1f5f9;\n  color: #334155;\n}\n\n.filter-summary span {\n  color: #1677ff;\n  font-size: 22px;\n  font-weight: 700;\n}\n\n.job-card {\n  height: 100%;\n  cursor: pointer;\n  transition: transform 0.2s ease, box-shadow 0.2s ease;\n}\n\n.job-card:hover {\n  transform: translateY(-4px);\n  box-shadow: 0 18px 50px rgba(22, 119, 255, 0.15);\n}\n\n.job-card-top {\n  display: flex;\n  justify-content: space-between;\n  gap: 16px;\n}\n\n.job-title-row {\n  display: flex;\n  flex-wrap: wrap;\n  align-items: center;\n  gap: 8px;\n}\n\n.job-title-row h3 {\n  margin: 0;\n  color: #111827;\n  font-size: 22px;\n}\n\n.job-meta {\n  margin-top: 8px;\n  color: #64748b;\n}\n\n.job-salary {\n  color: #1677ff;\n  font-size: 24px;\n  font-weight: 700;\n  white-space: nowrap;\n}\n\n.job-tags,\n.detail-tags,\n.detail-benefits