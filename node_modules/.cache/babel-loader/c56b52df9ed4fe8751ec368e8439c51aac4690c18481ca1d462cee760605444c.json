{"ast":null,"code":"import \"core-js/modules/es.array.reduce.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.reduce.js\";\nimport \"core-js/modules/es.object.to-string.js\";\nimport { companies } from \"../mock/jobs\";\nexport default {\n  name: \"CompanyHub\",\n  data: function data() {\n    return {\n      companies: companies\n    };\n  },\n  computed: {\n    totalOpenJobs: function totalOpenJobs() {\n      return this.companies.reduce(function (sum, item) {\n        return sum + item.openJobs;\n      }, 0);\n    }\n  }\n};","map":{"version":3,"names":["companies","name","data","computed","totalOpenJobs","reduce","sum","item","openJobs"],"sources":["src/views/CompanyHub.vue"],"sourcesContent":["<template>\n  <div class=\"page\">\n    <a-card :bordered=\"false\" class=\"banner-card\">\n      <div class=\"banner-copy\">\n        <a-tag color=\"purple\">企业品牌馆</a-tag>\n        <h2>集中展示优质雇主，强化招聘品牌感知</h2>\n        <p>支持企业介绍、岗位数量、行业分布与人才偏好展示，适合做 B 端客户招商页与求职者品牌页。</p>\n      </div>\n      <div class=\"banner-stats\">\n        <div class=\"stat-item\">\n          <div class=\"stat-value\">{{ companies.length }}</div>\n          <div class=\"stat-label\">合作企业</div>\n        </div>\n        <div class=\"stat-item\">\n          <div class=\"stat-value\">{{ totalOpenJobs }}</div>\n          <div class=\"stat-label\">开放岗位</div>\n        </div>\n      </div>\n    </a-card>\n\n    <a-row :gutter=\"[16, 16]\">\n      <a-col v-for=\"company in companies\" :key=\"company.id\" :xs=\"24\" :md=\"12\" :xl=\"8\">\n        <a-card :bordered=\"false\" class=\"company-card\">\n          <div class=\"company-head\">\n            <div class=\"company-mark\">{{ company.name.slice(0, 2) }}</div>\n            <div>\n              <h3>{{ company.name }}</h3>\n              <div class=\"company-meta\">{{ company.industry }} · {{ company.city }} · {{ company.district }}</div>\n            </div>\n          </div>\n          <p class=\"company-summary\">{{ company.summary }}</p>\n          <div class=\"company-data\">\n            <div>\n              <strong>{{ company.openJobs }}</strong>\n              <span>在招岗位</span>\n            </div>\n            <div>\n              <strong>{{ company.rating }}</strong>\n              <span>雇主评分</span>\n            </div>\n            <div>\n              <strong>{{ company.financing }}</strong>\n              <span>融资阶段</span>\n            </div>\n          </div>\n          <div class=\"company-tags\">\n            <a-tag>{{ company.scale }}</a-tag>\n            <a-tag color=\"blue\">{{ company.financing }}</a-tag>\n            <a-tag color=\"green\">{{ company.industry }}</a-tag>\n          </div>\n          <a-button type=\"primary\" ghost block @click=\"$router.push('/')\">查看该企业岗位</a-button>\n        </a-card>\n      </a-col>\n    </a-row>\n  </div>\n</template>\n\n<script>\nimport { companies } from \"../mock/jobs\";\n\nexport default {\n  name: \"CompanyHub\",\n  data() {\n    return {\n      companies\n    };\n  },\n  computed: {\n    totalOpenJobs() {\n      return this.companies.reduce((sum, item) => sum + item.openJobs, 0);\n    }\n  }\n};\n</script>\n\n<style scoped>\n.page {\n  display: flex;\n  flex-direction: column;\n  gap: 20px;\n}\n\n.banner-card,\n.company-card {\n  border-radius: 24px;\n  box-shadow: 0 12px 40px rgba(15, 23, 42, 0.08);\n}\n\n.banner-card {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 20px;\n  background: linear-gradient(135deg, #25124d 0%, #512da8 100%);\n  color: #fff;\n}\n\n.banner-copy h2 {\n  margin: 18px 0 10px;\n  color: #fff;\n  font-size: clamp(28px, 4vw, 40px);\n}\n\n.banner-copy p {\n  max-width: 700px;\n  color: rgba(255, 255, 255, 0.78);\n  font-size: 15px;\n  line-height: 1.8;\n}\n\n.banner-stats {\n  display: flex;\n  gap: 16px;\n}\n\n.stat-item {\n  min-width: 140px;\n  padding: 22px 20px;\n  border-radius: 20px;\n  background: rgba(255, 255, 255, 0.14);\n  text-align: center;\n}\n\n.stat-value {\n  font-size: 34px;\n  font-weight: 700;\n}\n\n.stat-label {\n  color: rgba(255, 255, 255, 0.72);\n}\n\n.company-card {\n  height: 100%;\n}\n\n.company-head {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n}\n\n.company-head h3 {\n  margin: 0;\n  font-size: 22px;\n  color: #0f172a;\n}\n\n.company-mark {\n  display: grid;\n  width: 58px;\n  height: 58px;\n  place-items: center;\n  border-radius: 18px;\n  background: linear-gradient(135deg, #1677ff, #5b8cff);\n  color: #fff;\n  font-size: 20px;\n  font-weight: 700;\n}\n\n.company-meta {\n  color: #64748b;\n}\n\n.company-summary {\n  min-height: 72px;\n  margin: 18px 0;\n  color: #475569;\n  line-height: 1.8;\n}\n\n.company-data {\n  display: grid;\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n  gap: 12px;\n  padding: 16px;\n  border-radius: 18px;\n  background: #f8fafc;\n}\n\n.company-data strong {\n  display: block;\n  color: #1677ff;\n  font-size: 24px;\n}\n\n.company-data span {\n  color: #64748b;\n  font-size: 13px;\n}\n\n.company-tags {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 8px;\n  margin: 18px 0;\n}\n\n@media (max-width: 900px) {\n  .banner-card {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n\n  .banner-stats {\n    width: 100%;\n  }\n}\n\n@media (max-width: 480px) {\n  .banner-stats,\n  .company-data {\n    grid-template-columns: 1fr;\n    display: grid;\n  }\n\n  .stat-item {\n    min-width: auto;\n  }\n}\n</style>\n"],"mappings":";;;;AA0DA,SAAAA,SAAA;AAEA;EACAC,IAAA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAF,SAAA,EAAAA;IACA;EACA;EACAG,QAAA;IACAC,aAAA,WAAAA,cAAA;MACA,YAAAJ,SAAA,CAAAK,MAAA,WAAAC,GAAA,EAAAC,IAAA;QAAA,OAAAD,GAAA,GAAAC,IAAA,CAAAC,QAAA;MAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}