{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: \"App\",\n  data: function data() {\n    return {\n      headerSearch: \"\",\n      mobileMenuOpen: false,\n      isScrolled: false,\n      navItems: [{\n        label: \"招聘广场\",\n        path: \"/\",\n        icon: \"🎯\"\n      }, {\n        label: \"企业专区\",\n        path: \"/companies\",\n        icon: \"🏢\"\n      }, {\n        label: \"投递管理\",\n        path: \"/delivery\",\n        icon: \"📋\"\n      }, {\n        label: \"数据大屏\",\n        path: \"/dashboard\",\n        icon: \"📊\"\n      }]\n    };\n  },\n  watch: {\n    \"$route.path\": function $routePath() {\n      this.mobileMenuOpen = false;\n    }\n  },\n  mounted: function mounted() {\n    window.addEventListener(\"scroll\", this.onScroll, {\n      passive: true\n    });\n  },\n  beforeDestroy: function beforeDestroy() {\n    window.removeEventListener(\"scroll\", this.onScroll);\n  },\n  methods: {\n    goSearch: function goSearch(keyword) {\n      if (!keyword && !this.headerSearch) return;\n      this.$router.push({\n        path: \"/\",\n        query: {\n          keyword: keyword || this.headerSearch\n        }\n      });\n    },\n    onScroll: function onScroll() {\n      this.isScrolled = window.scrollY > 10;\n    }\n  }\n};","map":{"version":3,"names":["name","data","headerSearch","mobileMenuOpen","isScrolled","navItems","label","path","icon","watch","$routePath","mounted","window","addEventListener","onScroll","passive","beforeDestroy","removeEventListener","methods","goSearch","keyword","$router","push","query","scrollY"],"sources":["src/App.vue"],"sourcesContent":["<template>\n  <a-layout class=\"app-shell\">\n    <a-layout-header class=\"app-header\" :class=\"{ scrolled: isScrolled }\">\n      <div class=\"header-inner\">\n        <div class=\"app-brand\" @click=\"$router.push('/')\">\n          <div class=\"brand-mark\">\n            <svg width=\"22\" height=\"22\" viewBox=\"0 0 22 22\" fill=\"none\">\n              <rect x=\"2\" y=\"2\" width=\"8\" height=\"8\" rx=\"2\" fill=\"white\" opacity=\"0.9\"/>\n              <rect x=\"12\" y=\"2\" width=\"8\" height=\"8\" rx=\"2\" fill=\"white\" opacity=\"0.6\"/>\n              <rect x=\"2\" y=\"12\" width=\"8\" height=\"8\" rx=\"2\" fill=\"white\" opacity=\"0.6\"/>\n              <rect x=\"12\" y=\"12\" width=\"8\" height=\"8\" rx=\"2\" fill=\"white\" opacity=\"0.3\"/>\n            </svg>\n          </div>\n          <div class=\"brand-text\">\n            <div class=\"brand-title\">智聘云台</div>\n            <div class=\"brand-subtitle\">智能招聘管理系统</div>\n          </div>\n        </div>\n\n        <nav class=\"app-nav\" :class=\"{ 'nav-open': mobileMenuOpen }\">\n          <div class=\"nav-overlay\" @click=\"mobileMenuOpen = false\" />\n          <div class=\"nav-panel\">\n            <router-link\n              v-for=\"item in navItems\"\n              :key=\"item.path\"\n              :to=\"item.path\"\n              class=\"app-nav-item\"\n              :class=\"{ active: $route.path === item.path }\"\n              @click=\"mobileMenuOpen = false\"\n            >\n              <span class=\"nav-icon\">{{ item.icon }}</span>\n              <span class=\"nav-label\">{{ item.label }}</span>\n              <span v-if=\"$route.path === item.path\" class=\"nav-dot\" />\n            </router-link>\n          </div>\n        </nav>\n\n        <div class=\"app-actions\">\n          <a-input-search\n            v-model=\"headerSearch\"\n            placeholder=\"搜索职位 / 企业 / 城市\"\n            class=\"header-search\"\n            @search=\"goSearch\"\n            @pressEnter=\"goSearch\"\n          />\n          <a-button type=\"primary\" shape=\"round\" class=\"header-cta\" @click=\"$router.push('/')\">\n            立即投递\n          </a-button>\n          <button class=\"hamburger\" :class=\"{ open: mobileMenuOpen }\" @click=\"mobileMenuOpen = !mobileMenuOpen\">\n            <span /><span /><span />\n          </button>\n     