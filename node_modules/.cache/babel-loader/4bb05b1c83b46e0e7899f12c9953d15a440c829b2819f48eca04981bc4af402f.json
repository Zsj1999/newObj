{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: \"App\",\n  data: function data() {\n    return {\n      navItems: [{\n        label: \"招聘广场\",\n        path: \"/\"\n      }, {\n        label: \"企业专区\",\n        path: \"/companies\"\n      }, {\n        label: \"投递管理\",\n        path: \"/delivery\"\n      }]\n    };\n  },\n  methods: {\n    goSearch: function goSearch(keyword) {\n      if (!keyword) {\n        return;\n      }\n      this.$router.push({\n        path: \"/\",\n        query: {\n          keyword: keyword\n        }\n      });\n    }\n  }\n};","map":{"version":3,"names":["name","data","navItems","label","path","methods","goSearch","keyword","$router","push","query"],"sources":["src/App.vue"],"sourcesContent":["<template>\n  <a-layout class=\"app-shell\">\n    <a-layout-header class=\"app-header\">\n      <div class=\"app-brand\">\n        <div class=\"brand-mark\">聘</div>\n        <div>\n          <div class=\"brand-title\">智聘云台</div>\n          <div class=\"brand-subtitle\">PC / H5 一体化招聘系统</div>\n        </div>\n      </div>\n      <div class=\"app-nav\">\n        <router-link\n          v-for=\"item in navItems\"\n          :key=\"item.path\"\n          :to=\"item.path\"\n          class=\"app-nav-item\"\n          :class=\"{ active: $route.path === item.path }\"\n        >\n          {{ item.label }}\n        </router-link>\n      </div>\n      <div class=\"app-actions\">\n        <a-input-search\n          placeholder=\"搜索职位 / 企业 / 城市\"\n          class=\"header-search\"\n          @search=\"goSearch\"\n        />\n        <a-button type=\"primary\" shape=\"round\">立即投递</a-button>\n      </div>\n    </a-layout-header>\n    <a-layout-content class=\"app-content\">\n      <router-view />\n    </a-layout-content>\n  </a-layout>\n</template>\n\n<script>\nexport default {\n  name: \"App\",\n  data() {\n    return {\n      navItems: [\n        { label: \"招聘广场\", path: \"/\" },\n        { label: \"企业专区\", path: \"/companies\" },\n        { label: \"投递管理\", path: \"/delivery\" }\n      ]\n    };\n  },\n  methods: {\n    goSearch(keyword) {\n      if (!keyword) {\n        return;\n      }\n      this.$router.push({\n        path: \"/\",\n        query: {\n          keyword\n        }\n      });\n    }\n  }\n};\n</script>\n\n<style scoped>\n.app-shell {\n  min-height: 100vh;\n  background: linear-gradient(180deg, #eff5ff 0%, #f7f9fc 30%, #f5f7fb 100%);\n}\n\n.app-header {\n  position: sticky;\n  top: 0;\n  z-index: 20;\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 20px;\n  height: auto;\n  padding: 16px 24px;\n  background: rgba(7, 20, 43, 0.88);\n  backdrop-filter: blur(12px);\n}\n\n.app-brand {\n  display: flex;\n  align-items: center;\n  gap: 14px;\n  min-width: 220px;\n}\n\n.brand-mark {\n  display: grid;\n  width: 44px;\n  height: 44px;\n  place-items: center;\n  border-radius: 14px;\n  background: linear-gradient(135deg, #1677ff, #52c41a);\n  color: #fff;\n  font-size: 22px;\n  font-weight: 700;\n}\n\n.brand-title {\n  color: #fff;\n  font-size: 20px;\n  font-weight: 700;\n  line-height: 1.2;\n}\n\n.brand-subtitle {\n  color: rgba(255, 255, 255, 0.72);\n  font-size: 12px;\n}\n\n.app-nav {\n  display: flex;\n  flex: 1;\n  justify-content: center;\n  gap: 12px;\n}\n\n.app-nav-item {\n  padding: 10px 16px;\n  border-radius: 999px;\n  color: rgba(255, 255, 255, 0.78);\n  font-weight: 500;\n  transition: all 0.2s ease;\n}\n\n.app-nav-item.active,\n.app-nav-item:hover {\n  background: rgba(255, 255, 255, 0.14);\n  color: #fff;\n}\n\n.app-actions {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n}\n\n.header-search {\n  width: min(320px, 42vw);\n}\n\n.app-content {\n  padding: 28px 24px 40px;\n}\n\n@media (max-width: 992px) {\n  .app-header {\n    flex-wrap: wrap;\n    padding: 16px;\n  }\n\n  .app-nav {\n    order: 3;\n    width: 100%;\n    justify-content: flex-start;\n    overflow-x: auto;\n    padding-bottom: 2px;\n  }\n\n  .app-actions {\n    flex: 1;\n    justify-content: flex-end;\n  }\n\n  .header-search {\n    width: 100%;\n    min-width: 180px;\n  }\n}\n\n@media (max-width: 640px) {\n  .app-brand {\n    min-width: auto;\n  }\n\n  .brand-subtitle {\n    display: none;\n  }\n\n  .app-actions {\n    width: 100%;\n    flex-direction: column;\n    align-items: stretch;\n  }\n\n  .app-content {\n    padding: 20px 14px 28px;\n  }\n}\n</style>\n"],"mappings":";AAqCA;EACAA,IAAA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,QAAA,GACA;QAAAC,KAAA;QAAAC,IAAA;MAAA,GACA;QAAAD,KAAA;QAAAC,IAAA;MAAA,GACA;QAAAD,KAAA;QAAAC,IAAA;MAAA;IAEA;EACA;EACAC,OAAA;IACAC,QAAA,WAAAA,SAAAC,OAAA;MACA,KAAAA,OAAA;QACA;MACA;MACA,KAAAC,OAAA,CAAAC,IAAA;QACAL,IAAA;QACAM,KAAA;UACAH,OAAA,EAAAA;QACA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}